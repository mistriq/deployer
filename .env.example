# HTTP listen address. Defaults to 127.0.0.1:9090.
DEPLOYER_ADDR=127.0.0.1:9090

# SQLite database path. Defaults to deployer.db.
DEPLOYER_DB_PATH=deployer.db

# Optional public URL used in generated runner setup commands.
DEPLOYER_PUBLIC_URL=https://deployer.example.com

# Runtime storage and retention.
DEPLOYER_ARTIFACT_DIR=/tmp/deployer-artifacts
DEPLOYER_SNAPSHOT_DIR=/tmp/deployer-snapshots
DEPLOYER_ARTIFACT_RETENTION_HOURS=24
DEPLOYER_LOG_RETENTION_DAYS=30

# Runtime timeouts use Go duration syntax.
DEPLOYER_SERVER_READ_TIMEOUT=30s
DEPLOYER_SERVER_WRITE_TIMEOUT=5m
DEPLOYER_DOCKER_BUILD_TIMEOUT=15m
DEPLOYER_SCP_TIMEOUT=10m
DEPLOYER_SSH_TIMEOUT=5m
DEPLOYER_HEALTH_CHECK_TIMEOUT=60s
DEPLOYER_AGENT_CONTROL_TIMEOUT=45s
DEPLOYER_AGENT_ARTIFACT_TIMEOUT=30m

# Optional: seed public-safe demo records into an empty database.
DEPLOYER_DEMO_MODE=false

# Broad Docker prune is disabled by default.
DEPLOYER_DOCKER_PRUNE=false

# Runner agents default to checksum-verified manual updates.
DEPLOYER_AGENT_AUTO_UPDATE=false
